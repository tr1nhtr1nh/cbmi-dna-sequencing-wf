Bootstrap: docker
From: alpine:3.20.2

%post
   apk update
   apk upgrade
   apk add bash tar libc6-compat libstdc++ libgcc python3

   wget https://github.com/bwa-mem2/bwa-mem2/releases/download/v2.2.1/bwa-mem2-2.2.1_x64-linux.tar.bz2
   tar x -j -f bwa-mem2-2.2.1_x64-linux.tar.bz2 --no-same-owner
   rm bwa-mem2-2.2.1_x64-linux.tar.bz2

%environment
   export PATH=$PATH:/bwa-mem2-2.2.1_x64-linux
