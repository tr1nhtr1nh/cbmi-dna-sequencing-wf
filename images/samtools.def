Bootstrap: docker
From: alpine:3.20.2

%post
    apk update
    apk upgrade
    apk add --no-cache make gcc g++ musl-dev zlib-dev bzip2-dev xz-dev curl-dev ncurses-dev 

    wget https://github.com/samtools/samtools/releases/download/1.22.1/samtools-1.22.1.tar.bz2
    tar x -j -f samtools-1.22.1.tar.bz2 --no-same-owner
    cd /samtools-1.22.1 && make
    cd / && rm samtools-1.22.1.tar.bz2
    
%environment
    export PATH=$PATH:/samtools-1.22.1
